# Database — https://neon.tech (free tier)
DATABASE_URL=

# AI Provider — "groq" (default), "grok", or "openai"
AI_PROVIDER=groq

# Groq — https://console.groq.com (free tier, fast)
GROK_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Grok/xAI (alternative — swap AI_PROVIDER=grok)
# GROK_API_KEY=
# GROK_MODEL=grok-3-mini

# OpenAI (alternative — swap AI_PROVIDER=openai)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Google PageSpeed Insights (optional — works without key, but rate-limited)
# GOOGLE_PAGESPEED_API_KEY=
